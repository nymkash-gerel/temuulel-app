# =============================================================================
# Temuulel Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in the values.
#
# Legend:
#   REQUIRED  — App will not function without this
#   OPTIONAL  — Feature disabled if unset, app still works
#   PUBLIC    — Exposed to browser (NEXT_PUBLIC_* prefix)
#   SERVER    — Server-only, never sent to client
#
# Rotation schedule:
#   Quarterly — OPENAI_API_KEY, RESEND_API_KEY, QSTASH_*, QPAY_PASSWORD, UPSTASH_REDIS_REST_TOKEN, SUPABASE_SECRET_KEY
#   On team change — SUPABASE_SECRET_KEY, CRON_SECRET
#   Annually — VAPID keys
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED) - Using Modern API Keys
# Get keys from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # PUBLIC  | REQUIRED
NEXT_PUBLIC_SUPABASE_KEY=sb_publishable_...                  # PUBLIC  | REQUIRED — Publishable key (safe for client)
SUPABASE_SECRET_KEY=sb_secret_...                            # SERVER  | REQUIRED — Secret key (server-only, never expose)

# DEPRECATED - Don't use these anymore (migrated to API keys 2026-02-23):
# NEXT_PUBLIC_SUPABASE_ANON_KEY (replaced by NEXT_PUBLIC_SUPABASE_KEY)
# SUPABASE_SERVICE_ROLE_KEY (replaced by SUPABASE_SECRET_KEY)

# -----------------------------------------------------------------------------
# App (REQUIRED)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app           # PUBLIC  | REQUIRED

# -----------------------------------------------------------------------------
# Facebook / Instagram (OPTIONAL — social integrations)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=                       # SERVER  | OPTIONAL
FACEBOOK_APP_SECRET=                   # SERVER  | OPTIONAL — rotate quarterly
FACEBOOK_PAGE_ACCESS_TOKEN=            # SERVER  | OPTIONAL
MESSENGER_VERIFY_TOKEN=                # SERVER  | OPTIONAL
INSTAGRAM_APP_ID=                      # SERVER  | OPTIONAL

# -----------------------------------------------------------------------------
# Telegram Bot (OPTIONAL — staff notifications via Telegram)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                    # SERVER  | OPTIONAL — rotate on compromise
TELEGRAM_BOT_USERNAME=                 # SERVER  | OPTIONAL
TELEGRAM_WEBHOOK_SECRET=               # SERVER  | OPTIONAL — set via setWebhook?secret_token=, verified in /api/webhook/telegram

# -----------------------------------------------------------------------------
# Email Notifications — Resend (OPTIONAL — email features)
# -----------------------------------------------------------------------------
RESEND_API_KEY=                        # SERVER  | OPTIONAL — rotate quarterly
NOTIFICATION_FROM_EMAIL=noreply@yourdomain.com  # SERVER  | OPTIONAL

# -----------------------------------------------------------------------------
# Web Push Notifications — VAPID (OPTIONAL — browser push)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=          # PUBLIC  | OPTIONAL
VAPID_PRIVATE_KEY=                     # SERVER  | OPTIONAL — rotate annually
VAPID_SUBJECT=mailto:support@yourdomain.com  # SERVER  | OPTIONAL

# -----------------------------------------------------------------------------
# Cron Job Security (OPTIONAL — required for scheduled tasks)
# -----------------------------------------------------------------------------
CRON_SECRET=                           # SERVER  | OPTIONAL — rotate on team change

# -----------------------------------------------------------------------------
# Upstash Redis (OPTIONAL — production rate limiting & caching)
# Get free credentials at https://console.upstash.com
# Without this, rate limiting uses in-memory store (single-instance only)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=                # SERVER  | OPTIONAL — e.g. https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=              # SERVER  | OPTIONAL — rotate quarterly

# -----------------------------------------------------------------------------
# Upstash QStash — Webhook Delivery (OPTIONAL — reliable webhook dispatch)
# -----------------------------------------------------------------------------
QSTASH_TOKEN=                          # SERVER  | OPTIONAL — rotate quarterly
QSTASH_CURRENT_SIGNING_KEY=            # SERVER  | OPTIONAL
QSTASH_NEXT_SIGNING_KEY=               # SERVER  | OPTIONAL

# -----------------------------------------------------------------------------
# OpenAI (OPTIONAL — if absent, AI features disabled, templates used instead)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                        # SERVER  | OPTIONAL — rotate quarterly

# -----------------------------------------------------------------------------
# QPay Payment Gateway (OPTIONAL — required for payments in Mongolia)
# -----------------------------------------------------------------------------
QPAY_BASE_URL=https://merchant.qpay.mn/v2  # SERVER  | OPTIONAL
QPAY_USERNAME=                         # SERVER  | OPTIONAL — rotate quarterly
QPAY_PASSWORD=                         # SERVER  | OPTIONAL — rotate quarterly
QPAY_INVOICE_CODE=                     # SERVER  | OPTIONAL

# -----------------------------------------------------------------------------
# SMS Gateway (OPTIONAL — SMS notifications)
# -----------------------------------------------------------------------------
SMS_API_URL=                           # SERVER  | OPTIONAL
SMS_API_KEY=                           # SERVER  | OPTIONAL — rotate quarterly

# -----------------------------------------------------------------------------
# Sentry Error Monitoring (OPTIONAL — error tracking & performance)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=                # PUBLIC  | OPTIONAL
SENTRY_DSN=                            # SERVER  | OPTIONAL — same value as above
SENTRY_AUTH_TOKEN=                     # SERVER  | OPTIONAL — for source map uploads
SENTRY_ORG=                            # SERVER  | OPTIONAL
SENTRY_PROJECT=                        # SERVER  | OPTIONAL

# Google Maps API (OPTIONAL — real road ETA for deliveries)
# Without this key, ETA uses district center coords + haversine (still works)
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: Distance Matrix API + Geocoding API
# Free tier: $200/month credit (~40,000 requests)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=                   # SERVER  | OPTIONAL
